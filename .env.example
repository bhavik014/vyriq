# ── Core ──────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string-eg-vyriq-2025-xj92kd8mpa

# ── AI ────────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Stripe (Payments) ─────────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret — from: Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs — from: Stripe Dashboard → Products (create Creator $29/mo and Agency $79/mo)
STRIPE_CREATOR_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# ── Email (SendGrid) ──────────────────────────────────────────────────
# Get your key at: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG....
# The email address Vyriq sends FROM (must be verified in SendGrid)
FROM_EMAIL=hello@vyriq.ai
FROM_NAME=Vyriq

# ── Admin Panel ───────────────────────────────────────────────────────
# Password to access /admin — choose something strong
ADMIN_PASSWORD=change-this-to-something-strong
ADMIN_EMAIL=your@email.com

# ── Database ──────────────────────────────────────────────────────────
# Leave blank locally (uses SQLite).
# Railway sets this automatically when you add a PostgreSQL addon.
DATABASE_URL=

# ── App URL ───────────────────────────────────────────────────────────
# Used for Stripe redirect URLs
APP_URL=https://vyriq.ai
